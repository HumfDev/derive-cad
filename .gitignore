# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test / lint / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors / OS
.DS_Store
.idea/
.vscode/

# Local runtime artifacts — never commit generated CAD output or user config
validation-snapshots/
*.step
*.stl
*.3mf
*.glb
*.gltf
.runs/
.derivecad.toml
credentials.toml

# Deliberate exception: small tracked fixture files
!tests/fixtures/*.step
!tests/fixtures/*.stl
